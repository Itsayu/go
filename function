package main

import "fmt"

// IN THE GO A FUNCTION CAN RETURN MULTIPLE VALUES

func add(a int, b int) int {
  // the 3rd int (out-side of () are type of return type)
  return a + b
}

// if our parameter type is same then we can write it at once
func subtract(a, b int) int {
  
  return a - b
}

func getLanguages() (string, string, string, string, string){
  return "goLang", "JavaScript", "TypeScript", "C++", "C#"
}

func getLanguage() (string, string, string, int, bool){
  return "goLang", "JavaScript", "TypeScript", 95, true
}

// IN THE GO FUNCTION ARE 1ST CLASS CITIZEN FUNCTION (i.e, a function can be pass as parameter or argument in another type)
func processIt(fn func(a int) int){
  fn(1)
}

func process() func(a int) int {
  return func(a int) int {
    return 4
  }
}


func main(){
  result := add(9, 5)
  fmt.Println(result)
  
  results := subtract(9, 5)
  fmt.Println(results)
  
  fmt.Println(getLanguages())
  // or
  lang1, lang2, lang3, lang4, lang5 := getLanguages()
  fmt.Println(lang1, lang2, lang3, lang4, lang5)
  
  fmt.Println(getLanguage())
  // or
  lan1, lan2, lan3, lan4, lan5 := getLanguage()
  fmt.Println(lan1, lan2, lan3, lan4, lan5)
  
  // if we want that any specific value then at that place we need to add "_" otherwise go compiler will give an error
  la1, la2, la3, _, la5 := getLanguage()
  fmt.Println(la1, la2, la3, la5)
  
  fn := func(a int) int {
    return 2 
  }
  
  processIt(fn)
  
  funct := process()
  funct(6)
  // fmt.Println(funct)
}
