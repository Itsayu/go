package main

// Struct 

import "fmt"
import "time"

// Order struct
type order struct {
  id string
  amount float32
  status string
  createdAt time.Time //nanosecond precision
}

func newOrder (id string, amount float32 ,status string) *order{
  myOrder1 := order {
    // if you don't set any filed, defult value is zero value
    // i.e, int => 0, float => 0, string => " ", bool => false
    id: id,
    amount: amount,
    status: status,
  }
  
  return &myOrder1
}

// reciver type
func (o *order) changeStatus(status string){
  // after the word func "()" will contain reciver type in general there is a convension that we write 1st letter of struct name in this case our struc is order so we write o, and we also written order which denotes type
  o.status = status
  
}

func (o order) getAmount() float32 {
  return o.amount
}

func main(){
  myOrder := order {
    // if you don't set any filed, defult value is zero value
