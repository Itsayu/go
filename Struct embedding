package main

// Struct embedding (in this we can redirect a struct in another struct)
import "fmt"

type customer struct {
  name string
  phone string
}

type order struct {
  id string
  amount float32
  status string
  customer
}

func main(){
  
  newCustomer := customer{
    name: "Ayush",
    phone: "+91 1234567890",
  }
  
  newOrder := order {
    id: "1",
    amount: 95,
    status: "Received",
    customer: newCustomer,
  }
  
  fmt.Println(newOrder)
  fmt.Println(newOrder.customer)

  fmt.Println(newCustomer)
  // fmt.Println(newOrder.customer)
}
